{
  "name": "deepseek-copilot-provider-custom",
  "displayName": "DeepSeek Provider for GitHub Copilot Chat (Custom)",
  "description": "Use DeepSeek, Anthropic, OpenAI Codex, and custom OpenAI-compatible models inside GitHub Copilot Chat through VS Code's Language Model Chat Provider API.",
  "version": "0.1.2",
  "publisher": "deepseek-copilot-provider-custom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "deepseek",
    "anthropic",
    "claude",
    "codex",
    "openai",
    "copilot",
    "language-models",
    "chat",
    "provider",
    "multi-provider"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseek.manage",
        "title": "Manage DeepSeek Provider"
      },
      {
        "command": "deepseek.openSettings",
        "title": "Open DeepSeek Provider Settings"
      },
      {
        "command": "deepseek.refreshModels",
        "title": "Refresh DeepSeek Models"
      },
      {
        "command": "anthropic.manage",
        "title": "Manage Anthropic Provider"
      },
      {
        "command": "anthropic.openSettings",
        "title": "Open Anthropic Provider Settings"
      },
      {
        "command": "anthropic.refreshModels",
        "title": "Refresh Anthropic Models"
      },
      {
        "command": "codex.manage",
        "title": "Manage OpenAI Codex Provider"
      },
      {
        "command": "codex.openSettings",
        "title": "Open OpenAI Codex Provider Settings"
      },
      {
        "command": "codex.refreshModels",
        "title": "Refresh OpenAI Codex Models"
      },
      {
        "command": "multiProvider.manageAll",
        "title": "Manage All Providers"
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "multi-provider-deepseek",
        "displayName": "DeepSeek",
        "managementCommand": "deepseek.manage"
      },
      {
        "vendor": "multi-provider-anthropic",
        "displayName": "Anthropic",
        "managementCommand": "anthropic.manage"
      },
      {
        "vendor": "multi-provider-codex",
        "displayName": "OpenAI Codex",
        "managementCommand": "codex.manage"
      }
    ],
    "configuration": {
      "title": "Multi-Provider",
      "properties": {
        "multiProvider.customProviders": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Display name for this custom provider"
              },
              "type": {
                "type": "string",
                "enum": ["openai", "anthropic", "codex"],
                "description": "API type: openai (OpenAI-compatible), anthropic, or codex"
              },
              "baseUrl": {
                "type": "string",
                "description": "Base URL for the API"
              }
            },
            "required": ["label", "type", "baseUrl"]
          },
          "markdownDescription": "Custom API providers you've added. Each one needs its own API key configured via the **Manage All Providers** command.",
          "scope": "application"
        },
        "multiProvider.deepseek.defaultFallbackModels": {
          "type": "array",
          "default": [
            "deepseek-v4-flash",
            "deepseek-v4-pro",
            "deepseek-chat",
            "deepseek-reasoner"
          ],
          "items": { "type": "string" },
          "markdownDescription": "Fallback model IDs for DeepSeek, used when /models endpoint is unreachable.",
          "scope": "application"
        },
        "multiProvider.deepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "markdownDescription": "Base URL for the DeepSeek API.",
          "scope": "application"
        },
        "multiProvider.anthropic.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com",
          "markdownDescription": "Base URL for the Anthropic API.",
          "scope": "application"
        },
        "multiProvider.codex.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "markdownDescription": "Base URL for the OpenAI Codex API.",
          "scope": "application"
        },
        "multiProvider.anthropic.defaultFallbackModels": {
          "type": "array",
          "default": [
            "claude-sonnet-4-20250514",
            "claude-opus-4-20250514",
            "claude-haiku-3-5-20250514"
          ],
          "items": { "type": "string" },
          "markdownDescription": "Fallback model IDs for Anthropic. (Anthropic doesn't have a public /models endpoint, so these are always used.)",
          "scope": "application"
        },
        "multiProvider.codex.defaultFallbackModels": {
          "type": "array",
          "default": [
            "gpt-5",
            "gpt-5-mini",
            "gpt-5-nano",
            "o4-mini"
          ],
          "items": { "type": "string" },
          "markdownDescription": "Fallback model IDs for OpenAI Codex, used when /v1/models endpoint is unreachable.",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^20.17.46",
    "@types/vscode": "^1.104.0",
    "typescript": "^5.8.3"
  }
}
